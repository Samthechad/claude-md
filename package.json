{
  "name": "claude-md",
  "version": "1.0.1",
  "description": "Auto-generate CLAUDE.md for your project using Claude AI",
  "main": "dist/index.js",
  "bin": {
    "claude-md": "./dist/index.js"
  },
  "keywords": [
    "claude",
    "anthropic",
    "claude-code",
    "CLAUDE.md",
    "ai",
    "cli",
    "developer-tools"
  ],
  "author": "Aurvena",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ora": "^8.0.1",
    "prompts": "^2.4.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "esbuild bin/index.js --bundle --platform=node --target=node18 --outfile=dist/index.js --format=cjs && node -e \"const fs=require(\"fs\");let c=fs.readFileSync(\"dist/index.js\",\"utf8\");c=c.replace(/^#!.*\\n/gm,\"\").trimStart();fs.writeFileSync(\"dist/index.js\",\"#!/usr/bin/env node\\n\"+c);require(\"fs\").chmodSync(\"dist/index.js\",\"755\")\"",
    "prepublishOnly": "npm run build"
  }
}